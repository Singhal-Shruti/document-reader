# Either ../.env (repository root) or new_approach/.env is loaded; both are
# checked, with the repo root taking precedence by default.

# OpenAI (required for embeddings and the journey agent's LLM)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Confluence Cloud (used by ingest-confluence)
CONFLUENCE_URL=https://your-tenant.atlassian.net/wiki
CONFLUENCE_USERNAME=you@example.com
CONFLUENCE_API_TOKEN=

# Jira Cloud (planned)
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

# GitHub (planned)
GITHUB_TOKEN=
